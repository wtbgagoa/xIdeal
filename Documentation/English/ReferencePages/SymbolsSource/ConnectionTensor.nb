Cell[TextData[{
 "There is only one parameter and no scalar functions. Then, we need to \
define the parameter (note that the symbol ",
 StyleBox["k", "Input"],
 " is already used as an abstract index):"
}], "ExampleText",
 CellChangeTimes->{{3.9157832135510273`*^9, 3.915783242136981*^9}, {
   3.91578329101208*^9, 3.915783308457185*^9}, {3.9167147119703255`*^9, 
