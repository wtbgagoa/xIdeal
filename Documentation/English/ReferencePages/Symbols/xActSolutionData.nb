                 AutoSpacing->False],
                $CellContext`z[],
                Editable->False], "2"]}]]}]]}], ")"}], "4"], ",", "0"}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", 
       SuperscriptBox[
        RowBox[{"(", 
