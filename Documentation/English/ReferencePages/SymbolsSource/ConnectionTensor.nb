   3.918701938209776*^9, 3.918701968220455*^9}, 3.918702492874895*^9, {
   3.918795048114605*^9, 3.918795071914923*^9}, {3.918795115780058*^9, 
   3.918795115780058*^9}, {3.9239744884793167`*^9, 3.9239745565310726`*^9}, {
