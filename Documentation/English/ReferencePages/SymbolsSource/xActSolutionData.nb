Cell[TextData[{
 "We can also get the ",
 Cell[BoxData[
 "CTensor"], "InlineFormula",ExpressionUUID->
  "0f868a15-f81d-4a36-8835-23f47a500897"],
 " expression which is ",
 StyleBox["xCoba's",
  FontSlant->"Italic"],
 " native way of handling tensor components: "
}], "ExampleText",
