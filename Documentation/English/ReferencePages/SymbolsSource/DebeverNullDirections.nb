Cell[CellGroupData[{

Cell["PetrovMatrix", "ExampleSubsubsection",
 CellChangeTimes->{{3.915784461677339*^9, 3.9157844643984385`*^9}},
 CellID->17838787,ExpressionUUID->"9032e16b-d798-a342-8643-aa82e560352f"],

Cell[TextData[{
 "The ",
 StyleBox["DebeverNullDirections", "Input"],
 " function can also determine the multiple Debever null directions of a \
metric by using the Petrov Matrix method. In that case however, it does not \
need an arbitrary bivector but, if metric is of Petrov Type D, an arbitrary \
vector or nothing otherwise. Let us first clear the cache:"
}], "ExampleText",
 CellChangeTimes->{{3.909634541358967*^9, 3.909634555814168*^9}, {
   3.9157839259270267`*^9, 3.915783939702003*^9}, {3.91578406420294*^9, 
   3.9157841764530087`*^9}, {3.9157842064708204`*^9, 3.915784214864062*^9}, {
   3.915784833177675*^9, 3.915784863528122*^9}, {3.9157849132543983`*^9, 
   3.9157849499215283`*^9}, {3.915785088348034*^9, 3.915785182558097*^9}, 
   3.915861977212243*^9, {3.916721388981499*^9, 3.9167215023720894`*^9}},
 CellID->487371356,ExpressionUUID->"ab85763e-6bdc-ff45-ab84-c6937d96c5ae"],

Cell[BoxData[
 RowBox[{"ClearxIdealCache", "[", "\"\<WeylConcomitants\>\"", "]"}]], "Input",\

 CellLabel->"In[11]:=",
 CellID->132427965,ExpressionUUID->"63288721-2cbe-9f46-8932-76d4df8bd4c2"],

Cell["\<\
Now, since Schwarzschild is of Petrov Type D, we define an arbitrary vector:\
\>", "ExampleText",
 CellChangeTimes->{{3.909634541358967*^9, 3.909634555814168*^9}, {
  3.9157839259270267`*^9, 3.915783939702003*^9}, {3.91578406420294*^9, 
