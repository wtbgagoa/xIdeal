     Cell[BoxData[
      RowBox[{"Parallelize", "[", 
       StyleBox["expr", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
      "7d3d416d-9b0d-483f-82bb-67b26f49d9a3"],
