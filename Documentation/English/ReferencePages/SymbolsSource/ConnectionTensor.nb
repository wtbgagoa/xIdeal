Cell[CellGroupData[{

Cell["Petrov homogeneous vacuum solution:", "ExampleSubsection",
 CellChangeTimes->{{3.9167146500921936`*^9, 3.9167146721890583`*^9}, {
  3.918701705325791*^9, 3.918701707823923*^9}, {3.9241433139447746`*^9, 
