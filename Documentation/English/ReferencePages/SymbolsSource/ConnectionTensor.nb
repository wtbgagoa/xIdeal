Cell[CellGroupData[{
Cell["ConnectionTensor", "ObjectName",
 CellID->493712759,ExpressionUUID->"b6de754d-bd01-4975-9ff0-6c3d3cba74ec"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"ConnectionTensor", "[", 
   RowBox[{"metric", ",", " ", "opts"}], "]"}]], "InlineFormula",
  ExpressionUUID->"ee462089-bcfd-49c8-8c40-e6af9a5ae212"],
 " returns the connection tensor of metric. The connection tensor is a tensor \
collecting the connection coefficients of a given metric."
}], "Usage",
 CellChangeTimes->{{3.918702011407051*^9, 3.918702058657692*^9}, {
  3.919499979625697*^9, 3.919500086574975*^9}, {3.9239718543265133`*^9, 
