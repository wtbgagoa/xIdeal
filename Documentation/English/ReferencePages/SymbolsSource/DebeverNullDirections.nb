Cell[TextData[{
 "Here, we will obtain the multiple Debever null directions of the \
Schwarzschild metric. We will load the metric by using the ",
 StyleBox["xActSolutionData",
  FontFamily->"Consolas",
  FontWeight->"Bold"],
 " function. We start by looking at the coordinate names:"
}], "ExampleText",
