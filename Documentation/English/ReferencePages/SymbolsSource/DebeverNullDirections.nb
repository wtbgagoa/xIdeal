Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"With", " ", "some", " ", 
      RowBox[{"restrictions", ".", " ", "We"}], " ", "should", " ", "check", 
      " ", "that", " ", "it", " ", "is", " ", "a", " ", "rank"}], "-", 
     RowBox[{"2", " ", "CTensor"}]}], ",", " ", 
    RowBox[{
    "antysymmetric", " ", "and", " ", "such", " ", "that", " ", "its", " ", 
     "necessary", " ", "contractions"}], ",", " ", 
    RowBox[{
     RowBox[{"i", ".", "e", ".", " ", 
      RowBox[{"scrp", "[", 
       RowBox[{
        RowBox[{"-", "a1"}], ",", 
        RowBox[{"-", "b1"}], ",", 
        RowBox[{"-", "i1"}], ",", 
        RowBox[{"-", "j1"}]}], "]"}]}], " ", 
