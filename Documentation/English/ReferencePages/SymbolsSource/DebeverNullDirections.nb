      RowBox[{"i1", ",", "j1"}], "]"}], " ", 
     RowBox[{"X", "[", 
      RowBox[{"k1", ",", "l1"}], "]"}]}], ",", " ", 
    RowBox[{"do", " ", "not", " ", 
     RowBox[{"vanish", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "We", " ", "should", " ", "also", " ", "group", " ", "options", " ", 
    "conveniently"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.916717184184906*^9, 3.916717211510542*^9}, {
  3.9181262782336903`*^9, 3.9181263206760807`*^9}, {3.9181265059200535`*^9, 
