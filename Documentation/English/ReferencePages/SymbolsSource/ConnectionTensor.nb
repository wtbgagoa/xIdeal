Cell["With the previous ingredients, we can get the metric tensor:", \
"ExampleText",
 CellChangeTimes->{{3.9332614347426023`*^9, 3.9332614450758877`*^9}, {
  3.933261543449223*^9, 3.933261566336285*^9}, {3.965123513211938*^9, 
  3.965123514546618*^9}, {3.979789479517063*^9, 3.979789479947891*^9}},
 CellID->2056787353,ExpressionUUID->"7d409f67-25f7-a64b-8244-25295a9d42bb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"metric", "=", 
  RowBox[{"xActSolutionData", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<PetrovSolution\>\"", ",", 
      RowBox[{"\"\<CanonicalCoordinates\>\"", "->", "char"}], ",", 
      RowBox[{"\"\<ParameterValues\>\"", "->", 
       RowBox[{"{", "kk", "}"}]}]}], "}"}], ",", "\"\<Metric\>\""}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.965033749051119*^9, 3.965033776049879*^9}, {
   3.96503443802849*^9, 3.9650345390227633`*^9}, {3.965034649980215*^9, 
   3.965034657031458*^9}, {3.9650348617687387`*^9, 3.965034871624452*^9}, 
   3.965042037451641*^9, {3.965042084693678*^9, 3.965042095127563*^9}, {
