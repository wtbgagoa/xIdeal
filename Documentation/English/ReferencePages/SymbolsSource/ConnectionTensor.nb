  $Line = 0; Null]], "ExampleDelimiter",
 CellID->74170913,ExpressionUUID->"dde637df-d1ac-674b-94da-8d9082374719"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$DefInfoQ", "=", "False"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DefManifold", "[", 
   RowBox[{"M", ",", "4", ",", 
    RowBox[{"IndexRange", "[", 
     RowBox[{"a", ",", "n"}], "]"}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{3.9167173072137833`*^9},
 CellLabel->"In[1]:=",
 CellID->138527017,ExpressionUUID->"63e428b4-89cf-9d41-bbc0-cde15e735936"],

Cell[TextData[{
 "Here, we will obtain the connection tensor (see ",
 ButtonBox["S\.13aez J A, Mengual S and Ferrando J J 2023 Class. Quantum \
Grav. 40 205020",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/2309.14100"], None},
  ButtonNote->"https://arxiv.org/abs/2309.14100"],
 " for its definition) of Petrov homogeneous vacuum solution (see ",
 ButtonBox["Petrov A Z 1962 Gravitational Field Geometry as the Geometry of \
Automorphisms (Recent Developments in General Relativity) (Pergamon) p 379",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dokumen.pub/recent-developments-in-general-relativity.html"],
     None},
  ButtonNote->
   "https://dokumen.pub/recent-developments-in-general-relativity.html"],
 "). We will load the metric by using the ",
 StyleBox["xActSolutionData",
  FontFamily->"Consolas",
  FontWeight->"Bold"],
 " function. We start by looking at the coordinate names:"
}], "ExampleText",
 CellChangeTimes->{{3.9157832135510273`*^9, 3.915783242136981*^9}, {
   3.91578329101208*^9, 3.915783308457185*^9}, {3.9167147119703255`*^9, 
   3.916714722688448*^9}, {3.918701737439493*^9, 3.918701758547952*^9}, {
   3.918701938209776*^9, 3.918701968220455*^9}, 3.918702492874895*^9, {
   3.918795048114605*^9, 3.918795071914923*^9}, {3.918795115780058*^9, 
   3.918795115780058*^9}, {3.9239744884793167`*^9, 3.9239745565310726`*^9}, {
   3.9797880827971745`*^9, 3.9797881180509033`*^9}, {3.9797882132307167`*^9, 
   3.9797882387733097`*^9}, {3.9797882789117393`*^9, 3.9797882883005486`*^9}, 
   3.9809301017416897`*^9},
 CellID->50967587,ExpressionUUID->"d6b66990-b37e-354d-99f0-75bbaac39314"],

