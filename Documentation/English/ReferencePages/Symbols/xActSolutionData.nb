Cell["\<\
With the previous ingredients, we can get the matrix expression of the metric \
tensor:\
\>", "ExampleText",
 CellID->2056787353,ExpressionUUID->"641c917a-9f54-4ad7-85ae-8a4275d24590"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"metric", "=", 
  RowBox[{
   RowBox[{"xActSolutionData", "[", 
    RowBox[{"\"\<Friedmann\>\"", ",", "\"\<Metric\>\""}], "]"}], "[", 
