Cell[TextData[{
 "Here, we will obtain the connection tensor of Wils solution (see ",
 ButtonBox["Wils P 1989 Class. Quantum Grav. 6 1243",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://iopscience.iop.org/article/10.1088/0264-9381/6/9/009"], None},
  ButtonNote->"https://iopscience.iop.org/article/10.1088/0264-9381/6/9/009"],
 "). We start by defining the coordinates and the metric:"
}], "ExampleText",
 CellChangeTimes->{{3.9157832135510273`*^9, 3.915783242136981*^9}, {
   3.91578329101208*^9, 3.915783308457185*^9}, {3.9167147119703255`*^9, 
