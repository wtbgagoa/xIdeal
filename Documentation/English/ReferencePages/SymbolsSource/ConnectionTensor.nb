Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "213bf0fc-3003-4ab9-bb06-d962f8debb49"], "Rframe", 
    RowBox[{"{", 
     RowBox[{"Null", ",", "Null", ",", "Null", ",", "Null"}], "}"}], Cell["\<\
An invariant frame that can be built from the Riemann tensor and its \
covariant derivatives.\
\>", "TableText",ExpressionUUID->"e4388a7d-85fc-4986-8957-ff7187a70f6a"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "020d7cc3-7650-4390-a72b-77dfbff27132"], 
    ButtonBox["PSimplify",
     BaseStyle->"Link",
     ButtonData->"paclet:xIdeal/ref/PSimplify"], "$CVSimplify", Cell["\<\
PSimplify is an option to choose the function used to simplify expressions.\
\>", "TableText",ExpressionUUID->"b7977dc7-15f1-4ef8-a0bd-ba34cb850987"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "b039da00-9a83-4795-834d-991aff00e957"], 
